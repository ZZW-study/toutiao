MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER="root"
MYSQL_PASSWORD=200306067911zzw
MYSQL_DB_NAME="news_app"
MYSQL_DB_POOL_SIZE=20
MYSQL_DB_OVERFLOW=40


REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=


# ====================== 令牌桶限流配置 ======================
# 令牌桶容量（支持突发流量）
TOKEN_BUCKET_CAPACITY=100
# 令牌生成速率（个/秒）
TOKEN_RATE=50.0
# 限流维度：ip/user_id/combined
RATE_LIMIT_DIMENSION=combined

# ====================== 接口防刷配置 ======================
# IP访问频率限制（次/分钟）
IP_RATE_LIMIT=600
# 用户访问频率限制（次/分钟）
USER_RATE_LIMIT=600
# 恶意请求阈值（次/秒）
MALICIOUS_THRESHOLD=10
# 黑名单封禁时间（秒）
BLACKLIST_DURATION=3600
# 滑动窗口大小（秒）
SLIDING_WINDOW_SIZE=60

# ====================== 降级与监控配置 ======================
# 是否启用本地限流降级
ENABLE_LOCAL_FALLBACK=true
# 限流触发后的重试时间（秒）
RETRY_AFTER=1
# 是否记录限流日志
ENABLE_RATE_LIMIT_LOGGING=true


# ====================== LLM Agent 配置 ======================
# OpenAI API Key（必填，用于调用 LLM）
OPENAI_API_KEY=your_openai_api_key_here
# OpenAI API 地址（可选，默认为官方地址，可配置代理）
OPENAI_API_BASE=https://api.openai.com/v1
# 使用的模型名称
LLM_MODEL=gpt-4o-mini

# ====================== RAG 向量检索配置 ======================
# Chroma 向量数据库持久化目录
CHROMA_PERSIST_DIR=./data/chroma
# Embedding 模型名称（支持中文的多语言模型）
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# 模型缓存目录
TRANSFORMERS_CACHE=./data/models

