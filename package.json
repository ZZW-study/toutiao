{
  "name": "toutiao-dev-launcher",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k --names server,client --prefix-colors cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "python -m uvicorn main:app --host 127.0.0.1 --port 8000 --lifespan off",
    "dev:client": "npm --prefix client run dev -- --host 127.0.0.1",
    "setup:client": "npm --prefix client install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
